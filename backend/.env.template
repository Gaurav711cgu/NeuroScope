# NeuroScope v2 — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Firebase ────────────────────────────────────────────────────────────────
# Path to downloaded service account key file (e.g. ./firebase-adminsdk.json)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Alternatively, paste raw JSON string (ideal for production environment variables)
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type": "service_account", ...}'

# Storage bucket name from Firebase Storage dashboard (e.g. project-id.appspot.com)
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# ─── Anthropic / Emergent Universal Key ────────────────────────────────────────
# Official Anthropic API Key (e.g. sk-ant-...)
ANTHROPIC_API_KEY=sk-ant-...

# Alternatively, you can use your Emergent Universal LLM Key (e.g. emg-sk-...)
# EMERGENT_LLM_KEY=emg-sk-...

# ─── HuggingFace ─────────────────────────────────────────────────────────────
# Required to download Gemma-2-2b-it (must accept license first at:
#   https://huggingface.co/google/gemma-2-2b-it)
HF_TOKEN=hf_...

# ─── Model config ────────────────────────────────────────────────────────────
# These have sensible defaults — only override if needed
NEUROSCOPE_MODEL=google/gemma-2-2b-it
NEUROSCOPE_SAE_RELEASE=gemma-scope-2b-pt-res
NEUROSCOPE_SAE_LAYER=12          # Layer 12 of 26 = mid-model
NEUROSCOPE_THREADS=4

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# For local dev: http://localhost:3000
# For production: your Vercel URL
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
